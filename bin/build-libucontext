#!/bin/sh

# Any build script should actually be in Makefile.tmpl and get configured by configure.

GITDIR="$HOME"/git
LUCDIR="$GITDIR"/libucontext

CPU_TYPE=`uname -m`
case "$CPU_TYPE" in
    'i386') ARCH=x86 ;;
    'macppc') ARCH=ppc ;;
esac

if [ ! -d "$LUCDIR" ]
then
    mkdir -p "$GITDIR"
    cd "$GITDIR"
    git clone git@github.com:kaniini/libucontext.git
fi
cd "$LUCDIR"

if type gmake > /dev/null 2>&1
then
    echo gmake is installed
else
    doas pkg_add gmake
fi
#gmake ARCH="$ARCH" FREESTANDING=yes EXPORT_UNPREFIXED=yes || exit
gmake ARCH="$ARCH" EXPORT_UNPREFIXED=yes || exit

# This does not work because headers are in /usr/include/libucontext not /usr/include...
#gmake ARCH="$ARCH" FREESTANDING=yes EXPORT_UNPREFIXED=yes check || exit

doas gmake ARCH="$ARCH" install



