#!/bin/sh

# shellcheck disable=SC2006

#
# Config script to tune m2c on machine-dependent things and on used C compiler.
#   Copyright (C) 1993-1997 (see more details in file COPYING).
#
# This file is part of Modula-2 translator.
#

#
# Configuration script to tune m2c
#  on machine-dependent things and
#  on used C compiler.
#
# Usage: configure [+srcdir=SRCDIR] [+cc=CCOMPILER]
#	 where
#              SRCDIR is directory of sources,
#                        for example /usr/local/src/m2c-0.7;
#              CCOMPILER is name C compiler that will be used by m2c,
#                           for example gcc, berkley-cc or pcc.
#
#  Configure ignores next options:
#              +nfp +gas +x.
#
# If configure succeeds, it leaves its status in config.status.
# If configure fails after disturbing the status quo,
# 	config.status is removed.
#

# Using external shell scripts instead of functions to maintain backward compatibility with ancient shells.
PATH="$PATH:bin"
OS=`uname -s`
config_file=m2-config.h
remove='rm -f';
program_name=`basename "$0"`
temp_file=xxxxx;

export PATH program_name OS temp_file


if test -f $temp_file
then
  write-error "Please delete $temp_file and try again." && exit 1
fi

cpu=generic
for arg in "$@"
do
  case $arg in
    +srcdir=* | srcdir=*)
      srcdir=`echo $arg | sed -E 's/^\+?srcdir=//'`;
      ;;
    +cc=* | cc=*)
      C_compiler=`echo $arg | sed -E 's/^\+?cc=//'`;
      ;;
    +cpu=* | cpu=*)
      cpu=`echo $arg | sed -E 's/^\+?cpu=//'`;
      ;;
    +nfp | +gas | +x)
      ;;
    +*)
      write-error "Unrecognized option \`$arg'. Good bye." && exit 1
      ;;
    -*)
      write-error "Use + instead of - for starting option \`$arg'. Good bye." && exit 1
      ;;
    *)
      cpu=$arg;
      ;;
  esac
done

# Find the source files, if location was not specified.
if is-empty "$srcdir"
then
	implicit_srcdir=1;
	srcdir=.;
	if test ! -f m2-semantics.c
	then
		srcdir=..;
	fi
fi

# Test sources availability.
if test ! -f "${srcdir}"/m2-semantics.c
then
	if is-empty "$implicit_srcdir"
	then
	  write-error "Can't find m2c sources in \`${srcdir}'." && exit 1
	else
	  write-error "Can't find m2c sources in \`.' or \`..'." && exit 1
	fi
fi

# Process argument CPU (source directory is already known).
if canonical_name=`get-canonical-cpu "$cpu"`
then
  cpu=`echo "$canonical_name" | sed s/-.*//`;
else
  exit 1;
fi


if is-empty "$cpu"
then
	write-error "Machine is not defined." && exit 1
fi


# If C compiler name was not specified, try to find it automatically.
if is-empty "$C_compiler"
then
  if type gcc >/dev/null 2>&1
  then
    C_compiler=gcc
    echo Detected gcc
  elif type egcc >/dev/null 2>&1
  then
    C_compiler=egcc
    echo Detected egcc
  fi
fi

# Suggest which compiler to install.
if is-empty "$C_compiler"
then
  if equals "$OS" "OpenBSD"
  then
    write-error "Install egcc and try again." && exit 1
  elif equals "$OS" "Linux"
  then
    write-error "Install gcc and try again." && exit 1
  fi
fi

if is-empty "$C_compiler"
then
	# `+cc' option was not specified. Ask C compiler name.
	for i in "${srcdir}"/config/*; do
		case $i in
      "${srcdir}"/config/"${cpu}"-*.h)
        C_compiler_exists=x;
        ;;
      *)
        ;;
		esac
	done

	if is-empty "$C_compiler_exists"
	then
		write-error "C compiler for $cpu has not been configured." && exit 1
	fi

	echo "Enter name of C compiler. The possible names are:";
	for i in "${srcdir}"/config/"${cpu}"-*.h
	do
		basename "$i" | sed "s/${cpu}-//" | sed "s/\\.h\$//"
	done

  echo "Compiler?";
  # shellcheck disable=SC2162
  read C_compiler;
fi

config_template=${cpu}-${C_compiler}.h;

# Test C compiler name.
if test ! -f "${srcdir}"/config/"$config_template"
then
	write-error "file \`config/$config_template' does not exist." && exit 1
fi


#------------------------------------------------
# Directory setup
#------------------------------------------------
if equals "$OS" "OpenBSD"
then
  echo "Configuring installation directories for OpenBSD." >> "$temp_file"
  # OpenBSD inappropriately installs all its prebuilt packages into /usr/local
  # but we're stuck with that unless we force the user to update PATH and
  # specify the includes and libs on every command...
  PREFIX=/usr/local
  BINDIR="$PREFIX"/bin
  LIBDIR="$PREFIX"/libdata/m2c
  MAN1DIR="$PREFIX"/man/man1
  INCLUDEDIR="$PREFIX"/include
  DOCDIR="$PREFIX"/share/doc/m2c
  if test ! -f /usr/include/libucontext/ucontext.h || test ! -f /usr/lib/libucontext.a
  then
    write-error "libucontext is required on OpenBSD. Please install it and try again." && exit 1
  else
    echo "libucontext detected. Adding include and link flags." >> "$temp_file"
    EXTERN_CFLAGS='-I/usr/include/libucontext'
    EXTERN_LDFLAGS='-lucontext'
  fi
elif equals "$OS" "Linux"
then
  echo "Configuring installation directories for Linux." >> "$temp_file"
  PREFIX=/usr/local
  BINDIR="$PREFIX"/bin
  LIBDIR="$PREFIX"/lib/m2c
  MAN1DIR="$PREFIX"/share/man/man1
  INCLUDEDIR="$PREFIX"/include
  DOCDIR="$PREFIX"/share/doc/m2c
else
  echo "Configuring installation directories with default settings." >> "$temp_file"
  PREFIX=/usr/local
  BINDIR="$PREFIX"/bin
  LIBDIR="$PREFIX"/m2clib
  MAN1DIR="$PREFIX"/man/man1
  INCLUDEDIR="$PREFIX"/include
  DOCDIR="$PREFIX"/share/doc/m2c
fi
# shellcheck disable=SC2129
echo PREFIX=/usr/local >> "$temp_file"
echo BINDIR="$PREFIX"/bin >> "$temp_file"
echo LIBDIR="$PREFIX"/m2clib >> "$temp_file"
echo MAN1DIR="$PREFIX"/man/man1 >> "$temp_file"
echo INCLUDEDIR="$PREFIX"/include >> "$temp_file"
echo DOCDIR="$PREFIX"/share/doc/m2c >> "$temp_file"

M2C_VERSION=`grep M2C_VERSION m2-version.h | cut -d' ' -f3 | tr -d '"'`

#------------------------------------------------
# Generate Makefile and config files
#------------------------------------------------


echo "# This file is generated automatically! Change \`Makefile.tmpl' and then run \`configure' again." >Makefile;
# The following format of multiple sed commands in a pipeline is the only
# one that is supported by BSD and ancient systems like Ultrix. It is inefficient
# but it is portable.
sed "s/^srcdir.*=.*\$/srcdir = ${srcdir}/" "${srcdir}"/Makefile.tmpl \
  | sed "s/^CC.*=.*\$/CC = ${C_compiler}/" \
  | sed "s!^prefix.*=.*\$!prefix = ${PREFIX}!" \
  | sed "s!^bindir.*=.*\$!bindir = ${BINDIR}!" \
  | sed "s!^libdir.*=.*\$!libdir = ${LIBDIR}!" \
  | sed "s!^man1dir.*=.*\$!man1dir = ${MAN1DIR}!" \
  | sed "s!^includedir.*=.*\$!includedir = ${INCLUDEDIR}!" \
  | sed "s!^docdir.*=.*\$!docdir = ${DOCDIR}!" \
  | sed "s!^M2C_VERSION.*=.*\$!M2C_VERSION = ${M2C_VERSION}!" \
  | sed "s!^EXTERN_CFLAGS.*=.*\$!EXTERN_CFLAGS = ${EXTERN_CFLAGS}!" \
  | sed "s!^EXTERN_LDFLAGS.*=.*\$!EXTERN_LDFLAGS = ${EXTERN_LDFLAGS}!" >> Makefile || exit

cat "${srcdir}"/config/"${config_template}" >"${config_file}";

# Assume coroutines (using makecontext/swapcontext) are always available.
echo "#define COROUTINE_ENABLE" >>"${config_file}";

echo "m2c is now configured for use on a(n) $cpu machine with the $C_compiler compiler." >> "$temp_file";
echo Source directory is: "$srcdir" >> "$temp_file";


cat "$temp_file" | tee config.status;
$remove "$temp_file";
